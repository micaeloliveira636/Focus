# Chaves de API do MazyOS — copie pra .env e preencha com os valores reais.
# O .env NUNCA vai pro git (está no .gitignore).

# OpenAI — geração de imagens (skill /carrossel com foto IA)
OPENAI_API_KEY=sk-cole-sua-chave-aqui

# Meta Graph API — publicação automática (skill /aprovar-post)
META_PAGE_ACCESS_TOKEN=
META_PAGE_ID=
META_IG_USER_ID=

# Site (skill /aprovar-post + /publicar-tema)
SITE_URL=
